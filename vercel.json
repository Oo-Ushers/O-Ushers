{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "node_modules/pg/**",
                    "node_modules/sequelize/**",
                    "node_modules/pg-hstore/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.js"
        }
    ],
    "git": {
        "deploymentEnabled": {
            "main": false,
            "staging": true
        }
    }
}